---
import { COMPANY } from '../data/company';

const year = new Date().getFullYear();

const nav = [
  { href: '/#what', label: 'What we do' },
  { href: '/#products', label: 'Products' },
  { href: '/#how', label: 'How we build' },
  { href: '/#company', label: 'Company' },
];

const legal = [
  { href: '/privacy', label: 'Privacy' },
  { href: '/terms', label: 'Terms' },
  { href: COMPANY.companiesHouseUrl, label: 'Companies House', external: true },
];
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-bg-elevated)]">
  <div class="container-page py-16">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr]">
      <div>
        <div class="flex items-center gap-2.5">
          <span
            class="grid h-7 w-7 place-items-center rounded-md border border-[var(--color-border-strong)] bg-[var(--color-surface)] text-[var(--color-accent)]"
            aria-hidden="true"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
              <path
                d="M12 3 21 20H3L12 3Z"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linejoin="round"></path>
              <path d="M8.4 16h7.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
              ></path>
            </svg>
          </span>
          <span class="text-[15px] font-semibold tracking-tight text-[var(--color-fg)]"
            >Aethon Labs</span
          >
        </div>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-[var(--color-fg-muted)]">
          A UK software product studio. We design, build and operate healthcare-grade SaaS.
        </p>
        <a
          href={`mailto:${COMPANY.email}`}
          class="mt-4 inline-block text-sm font-medium text-[var(--color-accent)] underline-offset-4 hover:underline"
        >
          {COMPANY.email}
        </a>
      </div>

      <nav aria-label="Footer" class="text-sm">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-fg-subtle)]">
          Explore
        </h2>
        <ul class="mt-4 space-y-3">
          {
            nav.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-[var(--color-fg-muted)] transition-colors hover:text-[var(--color-fg)]"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label="Legal" class="text-sm">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-fg-subtle)]">
          Legal
        </h2>
        <ul class="mt-4 space-y-3">
          {
            legal.map((link) => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noopener noreferrer' : undefined}
                  class="text-[var(--color-fg-muted)] transition-colors hover:text-[var(--color-fg)]"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div
      class="mt-12 flex flex-col gap-4 border-t border-[var(--color-border)] pt-8 text-xs leading-relaxed text-[var(--color-fg-subtle)] sm:flex-row sm:items-end sm:justify-between"
    >
      <p class="max-w-2xl">
        © {year} {COMPANY.legalName}. {COMPANY.companyType} registered in {
          COMPANY.jurisdiction
        }, company number {COMPANY.companyNumber}.
        <br />
        Registered office: {COMPANY.registeredOfficeOneLine}.
      </p>
      <p class="shrink-0">Made in the UK.</p>
    </div>
  </div>
</footer>
