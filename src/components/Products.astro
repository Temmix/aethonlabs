---
import SectionHeading from './SectionHeading.astro';
import { PRODUCTS } from '../data/company';
---

<section id="products" class="scroll-mt-20 border-t border-[var(--color-border)] py-24 sm:py-28">
  <div class="container-page">
    <SectionHeading
      eyebrow="Products"
      title="Our portfolio."
      description="One product, built properly, before the next. Each one owned and operated by Aethon Labs."
    />

    <div class="mt-14 grid gap-6 lg:grid-cols-2">
      {
        PRODUCTS.map((product) => (
          <article
            class="group relative flex flex-col overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-8 transition-colors hover:border-[var(--color-border-strong)]"
            data-reveal
          >
            <div
              class="pointer-events-none absolute -right-20 -top-20 h-56 w-56 rounded-full bg-[var(--color-accent)]/10 blur-3xl transition-opacity group-hover:opacity-80"
              aria-hidden="true"
            />
            <div class="relative flex items-center justify-between gap-4">
              <h3 class="text-2xl font-semibold tracking-tight text-[var(--color-fg)]">
                {product.name}
              </h3>
              <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-accent)]/30 bg-[var(--color-accent-soft)] px-3 py-1 text-xs font-medium text-[var(--color-accent)]">
                <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]" aria-hidden="true" />
                {product.status}
              </span>
            </div>

            <p class="relative mt-1 text-sm font-medium text-[var(--color-fg-subtle)]">
              {product.statusDetail}
            </p>

            <p class="relative mt-5 text-[15px] leading-relaxed text-[var(--color-fg-muted)]">
              {product.description}
            </p>

            <ul class="relative mt-6 flex flex-wrap gap-2">
              {product.tags.map((tag) => (
                <li class="rounded-md border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-2.5 py-1 text-xs font-medium text-[var(--color-fg-muted)]">
                  {tag}
                </li>
              ))}
            </ul>
          </article>
        ))
      }

      {/* Placeholder slot — keeps the grid balanced and signals more is coming. */}
      <article
        class="flex min-h-[220px] flex-col items-start justify-center rounded-2xl border border-dashed border-[var(--color-border-strong)] bg-transparent p-8"
        data-reveal
        aria-label="Future product"
      >
        <span
          class="grid h-10 w-10 place-items-center rounded-lg border border-[var(--color-border)] text-[var(--color-fg-subtle)]"
          aria-hidden="true"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
            <path
              d="M12 5v14M5 12h14"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"></path>
          </svg>
        </span>
        <h3 class="mt-5 text-lg font-semibold text-[var(--color-fg-muted)]">Product two</h3>
        <p class="mt-2 text-[15px] leading-relaxed text-[var(--color-fg-subtle)]">
          In the studio. We'll announce the next product when it's ready to be built right.
        </p>
      </article>
    </div>
  </div>
</section>
