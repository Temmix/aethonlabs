---
import SectionHeading from './SectionHeading.astro';

const groups = [
  {
    label: 'Engineering',
    items: [
      { name: 'FastAPI', note: 'Typed Python APIs' },
      { name: 'React + TypeScript', note: 'Strictly typed front end' },
      { name: 'PostgreSQL', note: 'Reliable, relational core' },
    ],
  },
  {
    label: 'Standards',
    items: [
      { name: 'FHIR R4', note: 'Health data interoperability' },
      { name: 'WCAG 2.2 AA', note: 'Accessible by design' },
      { name: 'ISO 8601 / OpenAPI', note: 'Predictable interfaces' },
    ],
  },
  {
    label: 'Trust & security',
    items: [
      { name: 'Cyber Essentials', note: 'Baseline security controls' },
      { name: 'UK GDPR', note: 'Data protection by default' },
      { name: 'Encryption in transit & at rest', note: 'Sensitive data, protected' },
    ],
  },
];
---

<section
  id="how"
  class="scroll-mt-20 border-t border-[var(--color-border)] bg-[var(--color-bg-elevated)] py-24 sm:py-28"
>
  <div class="container-page">
    <SectionHeading
      eyebrow="How we build"
      title="Built to standard. Engineered for trust."
      description="We work in a regulated, high-stakes domain, so we build like it. Modern engineering, recognised standards, and security treated as a first-class feature."
    />

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {
        groups.map((group) => (
          <div
            class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-7"
            data-reveal
          >
            <h3 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-fg-subtle)]">
              {group.label}
            </h3>
            <ul class="mt-5 space-y-4">
              {group.items.map((item) => (
                <li class="flex items-start gap-3">
                  <svg
                    class="mt-0.5 shrink-0 text-[var(--color-accent)]"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path
                      d="m5 12.5 4.5 4.5L19 7"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  <span>
                    <span class="block text-[15px] font-medium text-[var(--color-fg)]">
                      {item.name}
                    </span>
                    <span class="block text-sm text-[var(--color-fg-muted)]">{item.note}</span>
                  </span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
