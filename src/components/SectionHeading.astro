---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}
const { eyebrow, title, description } = Astro.props;
---

<div class="max-w-2xl" data-reveal>
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-accent)]">
    {eyebrow}
  </p>
  <h2
    class="mt-3 text-balance text-3xl font-semibold tracking-tight text-[var(--color-fg)] sm:text-4xl"
  >
    {title}
  </h2>
  {
    description && (
      <p class="mt-4 text-pretty text-lg leading-relaxed text-[var(--color-fg-muted)]">
        {description}
      </p>
    )
  }
</div>
